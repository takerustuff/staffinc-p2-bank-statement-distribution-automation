# Google OAuth — Drive read-only (no billing account needed).
# Create an OAuth "Desktop app" client in Google Cloud Console
# (APIs & Services -> Credentials), download as client_secret.json,
# or paste the ID/secret of an existing Web client here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only needed for Web-type clients (Desktop clients accept any port):
GOOGLE_OAUTH_PORT=8080

# Gmail SMTP sending — no Google Cloud API or billing needed.
# Enable 2-Step Verification, then generate an App Password at:
#   https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=
